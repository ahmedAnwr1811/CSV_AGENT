# ── LLM (OpenRouter is OpenAI-compatible) ───────────
# Put your OpenRouter key here (do NOT commit real keys)
OPENAI_API_KEY=YOUR_OPENROUTER_KEY_HERE

# Required for OpenRouter
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Choose a model available on your OpenRouter account
# Examples:
# LLM_MODEL=openai/gpt-4o-mini
# LLM_MODEL=openai/gpt-4o
LLM_MODEL=openai/gpt-4o-mini

# Optional: helps OpenRouter attribution/analytics
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=csv-agent

# ── MongoDB (sessions + messages) ───────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=csv_agent_db

# ── LangSmith tracing (optional) ─────────────────────
# Enable to see the full LangGraph/LLM run traces in LangSmith.
# Create an API key in LangSmith, then set:
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=YOUR_LANGSMITH_KEY_HERE
LANGCHAIN_PROJECT=csv-agent
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # default; set only if needed

# ── File storage ─────────────────────────────────────
UPLOAD_DIR=./uploads          # where CSV files are saved
MAX_CSV_ROWS=50000            # safety limit on CSV size

# ── App ──────────────────────────────────────────────
APP_NAME="CSV Data Science Agent"
DEBUG=false
